<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact VEXON</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
  <script defer src="https://kit.fontawesome.com/1d5f6e6140.js" crossorigin="anonymous"></script>
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">VEXON</a>
      <nav class="main-nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/men">Men</a>
        <a href="/women">Women</a>
        <a href="/kids">Kids</a>
        <a href="/contact">Contact</a>
      </nav>
      <div class="header-actions">
        <% if (user) { %>
          <a href="/dashboard" class="btn btn-secondary">Dashboard</a>
          <form action="/auth/logout" method="POST" style="display: inline;">
            <button type="submit" class="btn btn-tertiary">Logout</button>
          </form>
        <% } else { %>
          <a href="/auth/login" class="btn btn-secondary">Login</a>
          <a href="/auth/signup" class="btn btn-primary">Sign Up</a>
        <% } %>
      </div>
    </div>
  </header>

  <main class="section" style="padding-top:3rem;">
    <div class="container" style="max-width: 800px; margin:auto;">
      <div class="section-heading" style="text-align:center;margin-bottom:1.5rem;"><h2>Contact Us</h2><p>Reach out for support, orders, and feedback.</p></div>
      <form id="contactForm" style="display:grid;gap:1rem;background:var(--surface);border:1px solid var(--border);padding:1.5rem;border-radius:1rem;">
        <label>Name <input type="text" id="name" required style="width:100%;padding:0.7rem;border:1px solid var(--border);border-radius:0.55rem;background:var(--bg);color:#fff;"></label>
        <label>Phone Number <input type="tel" id="phone" required style="width:100%;padding:0.7rem;border:1px solid var(--border);border-radius:0.55rem;background:var(--bg);color:#fff;"></label>
        <label>Message <textarea id="message" rows="5" required style="width:100%;padding:0.7rem;border:1px solid var(--border);border-radius:0.55rem;background:var(--bg);color:#fff;"></textarea></label>
        <button type="submit" class="btn btn-primary">Send Message</button>
      </form>
      <section style="margin-top:2rem;background:var(--surface);border:1px solid var(--border);border-radius:1rem;padding:1rem;">
        <h3>Contact methods</h3>
        <ul style="list-style:none;padding:0;margin:0;color:var(--muted);">
          <li><i class="fab fa-whatsapp" style="color:var(--accent)"></i> WhatsApp: +964 770 000 0000</li>
          <li><i class="fab fa-instagram" style="color:var(--accent)"></i> Instagram: @vexonstreetwear</li>
          <li><i class="fas fa-envelope" style="color:var(--accent)"></i> Email: info@vexonstreetwear.iq</li>
        </ul>
      </section>
    </div>
  </main>

  <footer class="site-footer">
    <div class="container footer-top">
      <div class="footer-logo"><h3>VEXON</h3></div>
      <div class="footer-nav"><a href="/">Home</a><a href="/men">Men</a><a href="/women">Women</a><a href="/kids">Kids</a><a href="/contact">Contact</a></div>
      <div class="footer-social"><a href="#"><i class="fab fa-instagram"></i></a><a href="#"><i class="fab fa-tiktok"></i></a></div>
    </div>
    <div class="footer-bottom"><p>© 2026 VEXON Streetwear. All rights reserved.</p></div>
  </footer>
</body>
</html>