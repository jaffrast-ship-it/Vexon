<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard - VEXON Streetwear</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">VEXON</a>
      <nav class="main-nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/men">Men</a>
        <a href="/women">Women</a>
        <a href="/kids">Kids</a>
        <a href="/contact">Contact</a>
      </nav>
      <div class="header-actions">
        <a href="/dashboard" class="btn btn-secondary">Dashboard</a>
        <form action="/auth/logout" method="POST" style="display: inline;">
          <button type="submit" class="btn btn-tertiary">Logout</button>
        </form>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <h1>Customer Dashboard</h1>
      <p>Welcome back! Here you can manage your account and orders.</p>
      <!-- Add order history, account settings, etc. -->
      <div class="dashboard-content">
        <h2>Account Information</h2>
        <p>Role: <%= user.role %></p>
        <!-- More features can be added -->
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container footer-top">
      <div class="footer-logo"><h3>VEXON</h3></div>
      <div class="footer-nav"><a href="/">Home</a><a href="/men">Men</a><a href="/women">Women</a><a href="/kids">Kids</a><a href="/contact">Contact</a></div>
      <div class="footer-social"><a href="#"><i class="fab fa-instagram"></i></a><a href="#"><i class="fab fa-tiktok"></i></a></div>
    </div>
    <div class="footer-bottom"><p>© 2026 VEXON Streetwear. All rights reserved.</p></div>
  </footer>
</body>
</html>