<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Owner Dashboard - VEXON Streetwear</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">VEXON</a>
      <nav class="main-nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/admin">Dashboard</a>
        <a href="/admin/products/add">Add Product</a>
        <a href="/admin/categories">Categories</a>
        <a href="/admin/sizes">Sizes</a>
        <a href="/admin/contact">Contact</a>
        <a href="/owner">Owner</a>
      </nav>
      <div class="header-actions">
        <a href="/owner" class="btn btn-secondary">Owner Dashboard</a>
        <form action="/auth/logout" method="POST" style="display: inline;">
          <button type="submit" class="btn btn-tertiary">Logout</button>
        </form>
      </div>
    </div>
  </header>

  <section class="section admin-section">
    <div class="container">
      <h1>Owner Dashboard</h1>
      
      <% if (success) { %>
        <div style="color: green; margin-bottom: 1rem; display: flex; align-items: center;">
          <span style="margin-right: 0.5rem;">✓</span>
          <%= success %>
        </div>
      <% } %>
      
      <h2>Create Admin</h2>
      <form action="/owner/admins" method="POST">
        <div class="form-group">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" required />
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required />
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required />
        </div>
        <button type="submit" class="btn btn-primary">Create Admin</button>
      </form>

      <h2>Users</h2>
      <table class="admin-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(user => { %>
            <tr>
              <td><%= user.id %></td>
              <td><%= user.username %></td>
              <td><%= user.email %></td>
              <td>
                <form action="/owner/users/<%= user.id %>/role" method="POST" style="display: inline;">
                  <select name="role" onchange="this.form.submit()">
                    <option value="customer" <%= user.role === 'customer' ? 'selected' : '' %>>Customer</option>
                    <option value="admin" <%= user.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    <option value="owner" <%= user.role === 'owner' ? 'selected' : '' %>>Owner</option>
                  </select>
                </form>
              </td>
              <td><%= new Date(user.created_at).toLocaleDateString() %></td>
              <td>
                <form action="/owner/users/<%= user.id %>?_method=DELETE" method="POST" style="display: inline;">
                  <button type="submit" class="btn btn-tertiary" onclick="return confirm('Delete this user?')">Delete</button>
                </form>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container footer-top">
      <div class="footer-logo"><h3>VEXON</h3></div>
      <div class="footer-nav"><a href="/">Home</a><a href="/men">Men</a><a href="/women">Women</a><a href="/kids">Kids</a><a href="/contact">Contact</a></div>
      <div class="footer-social"><a href="#"><i class="fab fa-instagram"></i></a><a href="#"><i class="fab fa-tiktok"></i></a></div>
    </div>
    <div class="footer-bottom"><p>© 2026 VEXON Streetwear. All rights reserved.</p></div>
  </footer>
</body>
</html>