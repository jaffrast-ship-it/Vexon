<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - VEXON Streetwear</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">VEXON</a>
      <nav class="main-nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/men">Men</a>
        <a href="/women">Women</a>
        <a href="/kids">Kids</a>
        <a href="/contact">Contact</a>
      </nav>
      <div class="header-actions">
        <a href="/auth/login" class="btn btn-secondary">Login</a>
        <a href="/auth/signup" class="btn btn-primary">Sign Up</a>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container">
      <div class="auth-form">
        <h1>Login</h1>
        <% if (error) { %>
          <p class="error"><%= error %></p>
        <% } %>
        <form action="/auth/login" method="POST">
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required />
          </div>
          <button type="submit" class="btn btn-primary">Login</button>
        </form>
        <p>Don't have an account? <a href="/auth/signup">Sign up</a></p>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container footer-top">
      <div class="footer-logo"><h3>VEXON</h3></div>
      <div class="footer-nav"><a href="/">Home</a><a href="/men">Men</a><a href="/women">Women</a><a href="/kids">Kids</a><a href="/contact">Contact</a></div>
      <div class="footer-social"><a href="#"><i class="fab fa-instagram"></i></a><a href="#"><i class="fab fa-tiktok"></i></a></div>
    </div>
    <div class="footer-bottom"><p>© 2026 VEXON Streetwear. All rights reserved.</p></div>
  </footer>
</body>
</html>