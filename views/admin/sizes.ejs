<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Sizes - VEXON Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="logo" href="/">VEXON</a>
      <nav class="main-nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/admin">Dashboard</a>
        <a href="/admin/products/add">Add Product</a>
        <a href="/admin/categories">Categories</a>
        <a href="/admin/sizes">Sizes</a>
        <a href="/admin/contact">Contact</a>
        <% if (user.role === 'owner') { %>
          <a href="/owner">Owner</a>
        <% } %>
      </nav>
      <div class="header-actions">
        <a href="/admin" class="btn btn-secondary">Admin Dashboard</a>
        <form action="/auth/logout" method="POST" style="display: inline;">
          <button type="submit" class="btn btn-tertiary">Logout</button>
        </form>
      </div>
    </div>
  </header>

  <section class="section admin-section">
    <div class="container">
      <h1>Manage Sizes</h1>
      
      <% if (success) { %>
        <div style="color: green; margin-bottom: 1rem; display: flex; align-items: center;">
          <span style="margin-right: 0.5rem;">✓</span>
          <%= success %>
        </div>
      <% } %>
      
      <div class="admin-form">
        <h2>Add New Size</h2>
        <form action="/admin/sizes" method="POST">
          <div class="form-group">
            <label for="name">Size Name</label>
            <input type="text" id="name" name="name" required />
          </div>
          <button type="submit" class="btn btn-primary">Add Size</button>
        </form>
      </div>

      <h2>Existing Sizes</h2>
      <ul class="admin-list">
        <% sizes.forEach(size => { %>
          <li>
            <%= size.name %>
            <form action="/admin/sizes/<%= size.name %>?_method=DELETE" method="POST" style="display: inline;">
              <button type="submit" class="btn btn-tertiary" onclick="return confirm('Delete this size?')">Delete</button>
            </form>
          </li>
        <% }); %>
      </ul>
    </div>
  </section>
</body>
</html>